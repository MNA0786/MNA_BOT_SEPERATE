# ==============================
# HTACCESS CONFIGURATION - FIXED
# ==============================

# Enable Rewrite Engine
RewriteEngine On

# ===== FIX: Remove HTTPS redirect for Render.com =====
# Render.com already handles HTTPS, so this causes loop
# Comment out or remove these lines:

# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

# =====================================================

# Security Headers
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "DENY"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Block access to sensitive files
<FilesMatch "^(\.env|\.git|composer\.json|composer\.lock|error\.log|users\.json|bot_stats\.json|movie_requests\.json|user_settings\.json)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Block access to data directory
RewriteRule ^data/ - [F,L]

# Block access to backups directory
RewriteRule ^backups/ - [F,L]

# Prevent directory listing
Options -Indexes

# Custom error pages
ErrorDocument 403 /error.php?code=403
ErrorDocument 404 /error.php?code=404
ErrorDocument 500 /error.php?code=500

# PHP settings
<IfModule mod_php7.c>
    php_value upload_max_filesize 50M
    php_value post_max_size 50M
    php_value max_execution_time 300
    php_value max_input_time 300
    php_value memory_limit 256M
</IfModule>

# Compress text files
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>
